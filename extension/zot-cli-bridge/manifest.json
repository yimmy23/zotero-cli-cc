  "description": "Exposes Zotero Find Full Text and attachment rename over the local HTTP server for the zot CLI.",
  "author": "zotero-cli-cc",
  "homepage_url": "https://github.com/Agents365-ai/zotero-cli-cc",
  "icons": {
    "48": "icon.png",
    "96": "icon.png"
